# Server
PORT=3001
NODE_ENV=development

# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Redis — must be running locally for BullMQ job queues
REDIS_URL=redis://localhost:6379

# Retell AI (voice calls). Webhooks are verified with RETELL_API_KEY.
RETELL_API_KEY=your-retell-api-key
RETELL_FROM_NUMBER=+10000000000

# Shared secret for candidate-intake and cal-booking webhooks.
# Callers must send it in the x-webhook-secret header. Leave empty to disable (dev only).
WEBHOOK_SHARED_SECRET=

# Cal.com API (deadline backstop: cancel late bookings; per-job availability windows)
CAL_API_KEY=
# Numeric id of the event type candidates book (for per-job availability windows)
CAL_EVENT_TYPE_ID=
# Public booking link used in invitation emails
CAL_BASE_URL=https://cal.com/saanvitech/screen-interview-x-saanvi-tech
# Cal.com API version header for bookings endpoints
CAL_API_VERSION=2024-08-13

# CEIPAL ATS (job sync)
CEIPAL_API_KEY=your-ceipal-api-key
CEIPAL_EMAIL=your-ceipal-email
CEIPAL_PASSWORD=your-ceipal-password
# Graph mail intake: inbox poll cadence (minutes) and lookback window (days)
CEIPAL_MAIL_POLL_MINUTES=5
CEIPAL_MAIL_LOOKBACK_DAYS=3
# Encoded CEIPAL user id whose assigned jobs are in-scope for email intake
CEIPAL_RECRUITER_ID=

# Default org for server-side (non-authenticated) flows, e.g. the CEIPAL mail poller
DEFAULT_ORG_ID=

# OpenRouter (AI screening & reports)
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=openai/gpt-4o-mini

# Email transport: 'graph' (Microsoft Graph), 'smtp', or 'log' (dev — prints to console)
EMAIL_TRANSPORT=log
# Production SMTP (Resend recommended: smtp.resend.com / port 587 / user: resend)
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=your-resend-api-key
SMTP_FROM=noreply@yourdomain.com

# Microsoft Graph (email transport + CEIPAL notification-mail intake)
MS_GRAPH_CLIENT_ID=your-client-id
MS_GRAPH_CLIENT_SECRET=your-client-secret
MS_GRAPH_TENANT_ID=your-tenant-id
# Mailbox (UPN) that Graph sends from / polls, e.g. AISaanviHR@saanvi.us
MS_GRAPH_SENDER=

# Frontend URL for CORS (comma-separated for multiple origins)
FRONTEND_URL=http://localhost:8082,https://your-production-domain.com

# Public base URL of THIS backend (used for Retell post-call webhook URLs).
# Required in production, e.g. https://your-backend.up.railway.app
PUBLIC_API_URL=

# Recurring re-engagement sweep (auto-emails matched candidates for stale jobs
# every 6h). Sends real email on its own — keep 'false' unless explicitly wanted.
REENGAGEMENT_AUTO_SWEEP=false

# Self-service signup (creates a new org + admin, email pre-confirmed).
# Keep 'false' in production — team members join via admin invite.
ALLOW_PUBLIC_SIGNUP=false
