# Server
PORT=3001
NODE_ENV=development

# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Redis — must be running locally for BullMQ job queues
REDIS_URL=redis://localhost:6379

# Retell AI (voice calls)
RETELL_API_KEY=your-retell-api-key
RETELL_WEBHOOK_SECRET=your-retell-webhook-secret
RETELL_FROM_NUMBER=+10000000000

# CEIPAL ATS (job sync)
CEIPAL_API_KEY=your-ceipal-api-key
CEIPAL_EMAIL=your-ceipal-email
CEIPAL_PASSWORD=your-ceipal-password

# OpenRouter (AI screening & reports)
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=openai/gpt-4o-mini

# Email — use 'log' locally (prints to console), 'smtp' in production
EMAIL_TRANSPORT=log
# Production SMTP (Resend recommended: smtp.resend.com / port 587 / user: resend)
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=your-resend-api-key
SMTP_FROM=noreply@yourdomain.com

# Microsoft Graph / Outlook (optional — alternative email transport)
MS_GRAPH_CLIENT_ID=your-client-id
MS_GRAPH_CLIENT_SECRET=your-client-secret
MS_GRAPH_TENANT_ID=your-tenant-id
MS_GRAPH_REDIRECT_URI=http://localhost:3001/api/auth/microsoft/callback

# Frontend URL for CORS (comma-separated for multiple origins)
FRONTEND_URL=http://localhost:8082,https://your-production-domain.com
